# Copy to .env.local and configure your API keys

# Groq API key for PDF summarization (free tier, recommended)
# Get a key at https://console.groq.com
# Also used by the rate-limit worker (npm run worker) for automatic retries
GROQ_API_KEY=your-groq-api-key

# JWT secret for auth (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Simpeg login API (Bearer for https://e-arsip.kemenkum.go.id/.../login_simpeg)
PUSDATIN_BEARER_TOKEN=

# UNSAFE — local dev only. Disables TLS certificate verification for the whole Node process (all HTTPS, including Groq).
# PowerShell before npm run dev:  $env:NODE_TLS_REJECT_UNAUTHORIZED="0"
# Or uncomment (never enable in production):
# NODE_TLS_REJECT_UNAUTHORIZED=0