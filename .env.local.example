# Copy to .env.local and configure your API keys

# Groq API key for PDF summarization (free tier, recommended)
# Get a key at https://console.groq.com
# Also used by the rate-limit worker (npm run worker) for automatic retries
GROQ_API_KEY=your-groq-api-key

# JWT secret for auth (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-at-least-32-chars
