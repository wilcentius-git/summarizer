{
  "name": "summarizer",
  "version": "0.29.3",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "concurrently \"next dev\" \"npx tsx scripts/rate-limit-worker.ts\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently \"next start\" \"npx tsx scripts/rate-limit-worker.ts\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "npx tsx scripts/rate-limit-worker.ts",
    "install:gpu": "node scripts/install-gpu.js",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@napi-rs/canvas": "^0.1.93",
    "@prisma/client": "^6.0.0",
    "adm-zip": "^0.5.16",
    "bcrypt": "^6.0.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "jose": "^6.2.1",
    "jspdf": "^4.1.0",
    "mammoth": "^1.11.0",
    "next": "^16.1.6",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^5.0.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rtf-parser": "^1.3.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.47",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
